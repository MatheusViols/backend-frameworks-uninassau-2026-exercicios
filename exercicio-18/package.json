{
  "name": "exercicio-18-testes-unitarios",
  "version": "1.0.0",
  "description": "Exercício de testes unitários com Jest",
  "main": "src/index.js",
  "scripts": {
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": ["jest", "unit-tests", "mocks"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "sequelize": "^6.35.2"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
